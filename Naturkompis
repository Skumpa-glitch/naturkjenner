          '<div class="detail-item"><div class="detail-label">' + (species.edible ? '✅' : '❌') + ' Spiselig</div><div class="detail-value">' + (species.edible ? 'Ja' : 'Nei') + '</div></div>' +
        '</div>' +
        (species.funFact ? '<div class="fun-fact"><span style="font-size:16px;flex-shrink:0">💡</span><span>' + species.funFact + '</span></div>' : '') +
      '</div>' +
      '<div class="toggle-hint" id="hint-' + id + '">▼ Vis detaljer</div>' +
    '</div></div>';
}

function doSave(id) {
  const sp = speciesStore[id];
  if (!sp) return;
  toggleSave(sp);
  const btn = document.getElementById('save-' + id);
  if (btn) {
    const saved = isSaved(sp.name);
    btn.className = 'save-btn' + (saved ? ' saved' : '');
    btn.textContent = saved ? '✅' : '💾';
  }
}

function toggleDetails(id) {
  const det = document.getElementById('details-' + id);
  const hint = document.getElementById('hint-' + id);
  if (det) {
    const isOpen = det.classList.contains('open');
    det.classList.toggle('open');
    if (hint) hint.textContent = isOpen ? '▼ Vis detaljer' : '▲ Skjul detaljer';
  }
}

// ============================================================
// VIEWS
// ============================================================
function showResults(imageData, results, errorMsg) {
  const area = document.getElementById('resultsArea');
  document.getElementById('exploreArea').classList.add('hidden');

  if (errorMsg) {
    area.innerHTML = '<div class="fade-in" style="margin-top:20px">' +
      '<img src="' + imageData + '" class="preview-img" alt="Ditt bilde">' +
      '<div class="error-box"><h4>⚠️ Noe gikk galt</h4><p>' + errorMsg + '</p><p style="margin-top:8px">Prøv igjen, eller sjekk internettforbindelsen.</p></div></div>';
    return;
  }

  if (results.length > 0) {
    area.innerHTML = '<div class="fade-in" style="margin-top:20px">' +
      '<img src="' + imageData + '" class="preview-img" alt="Ditt bilde">' +
      '<div class="explore-title">🤖 AI-identifisering (' + results.length + ' treff)</div>' +
      results.map((r, i) => '<div class="fade-in fade-in-' + i + '">' + speciesCardHTML(r, i, true) + '</div>').join('') +
      '<div class="tip-box">💡 Drevet av Google Gemini AI. Trykk på kort for detaljer.</div></div>';
  } else {
    area.innerHTML = '<div class="fade-in" style="margin-top:20px">' +
      '<img src="' + imageData + '" class="preview-img" alt="Ditt bilde">' +
      '<div style="text-align:center;padding:30px"><div style="font-size:40px;margin-bottom:12px">🤔</div>' +
      '<div style="font-size:16px;font-weight:600;color:#555">AI-en klarte ikke å identifisiere noe</div>' +
      '<div style="font-size:13px;color:#888;margin-top:4px">Prøv et tydeligere bilde med bedre lys</div></div></div>';
  }
}

function showHome() {
  currentView = 'home';
  document.getElementById('homeView').classList.remove('hidden');
  document.getElementById('browseView').classList.add('hidden');
  document.getElementById('collectionView').classList.add('hidden');
  document.getElementById('resultsArea').innerHTML = '';
  document.getElementById('exploreArea').classList.remove('hidden');
  document.getElementById('navHome').classList.add('active');
  document.getElementById('navCollection').classList.remove('active');
}

function browseCategory(key) {
  currentView = 'browse';
  document.getElementById('homeView').classList.add('hidden');
  document.getElementById('collectionView').classList.add('hidden');
  const bv = document.getElementById('browseView');
  bv.classList.remove('hidden');
  const species = SPECIES_DB[key] || [];
  bv.innerHTML = '<button class="back-btn" onclick="showHome()">← Tilbake</button>' +
    '<div class="section-title">' + (CAT_NAMES[key] || key) + '</div>' +
    species.map((sp, i) => speciesCardHTML(sp, -1, false)).join('');
}

function showCollection() {
  currentView = 'collection';
  document.getElementById('homeView').classList.add('hidden');
  document.getElementById('browseView').classList.add('hidden');
  const cv = document.getElementById('collectionView');
  cv.classList.remove('hidden');
  document.getElementById('navHome').classList.remove('active');
  document.getElementById('navCollection').classList.add('active');

  if (collection.length === 0) {
    cv.innerHTML = '<div class="empty"><div class="empty-icon">🌿</div><h3>Samlingen din er tom</h3><p>Ta bilder og lagre artene du finner!</p>' +
      '<button class="camera-btn" style="margin-top:20px;max-width:250px;font-size:15px;padding:14px" onclick="showHome()">Start å utforske</button></div>';
    return;
  }

  const grouped = {};
  collection.forEach(item => { if (!grouped[item.category]) grouped[item.category] = []; grouped[item.category].push(item); });

  cv.innerHTML = '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px"><div>' +
    '<div class="section-title" style="margin-bottom:4px">Min samling</div>' +
    '<div style="font-size:13px;color:#888">' + collection.length + ' arter funnet</div></div></div>' +
    Object.entries(grouped).map(([cat, items]) =>
      '<div class="cat-title">' + cat + '</div>' +
      items.map(item => '<div class="collection-item"><div><div class="collection-item-name">' + item.name + '</div>' +
        '<div class="collection-item-latin">' + item.latin + '</div></div>' +
        '<button class="remove-btn" onclick="removeFromCollection(\'' + item.name.replace(/'/g, "\\'") + '\')">🗑️</button></div>').join('')
    ).join('');
}

function removeFromCollection(name) {
  collection = collection.filter(s => s.name !== name);
  updateCollectionCount();
  showCollection();
}
</script>
