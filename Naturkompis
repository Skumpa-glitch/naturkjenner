function resizeImage(dataUrl, maxWidth) {
  return new Promise(resolve => {
    const img = new Image();
    img.onload = () => {
      if (img.width <= maxWidth) { resolve(dataUrl); return; }
      const ratio = maxWidth / img.width;
      const canvas = document.createElement('canvas');
      canvas.width = maxWidth;
      canvas.height = Math.round(img.height * ratio);
      const ctx = canvas.getContext('2d');
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      resolve(canvas.toDataURL('image/jpeg', 0.85));
    };
    img.onerror = () => resolve(dataUrl);
    img.src = dataUrl;
  });
}

async function handleFile(e) {
  const file = e.target.files?.[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = async (ev) => {
    const rawData = ev.target.result;
    const imageData = await resizeImage(rawData, 1200);
    document.getElementById('overlay').classList.remove('hidden');
    document.getElementById('overlayText').textContent = 'Sender bildet til Google Gemini...';
    const btn = document.getElementById('cameraBtn');
    btn.classList.add('loading');
    btn.innerHTML = '<span class="spinner"></span> AI analyserer...';

    try {
      document.getElementById('overlayText').textContent = 'AI identifiserer arter...';
      const results = await identifyWithGemini(imageData);
      results.sort((a,b) => b.confidence - a.confidence);
      showResults(imageData, results);
    } catch(err) {
      showResults(imageData, [], err.message);
    } finally {
      document.getElementById('overlay').classList.add('hidden');
      btn.classList.remove('loading');
      btn.innerHTML = '<span style="font-size:24px">📸</span> Ta bilde eller velg fra galleri';
    }
  };
  reader.readAsDataURL(file);
  e.target.value = '';
}

