<!DOCTYPE html>
<html lang="no">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Naturkjenner">
<title>Naturkjenner</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --paper: #f7f3ec;
  --ink: #1e1c18;
  --forest: #1f3d2b;
  --leaf: #4a7c59;
  --mist: #a8c4b0;
  --sand: #d9cdb8;
  --warm: #e8e0d0;
  --rust: #b05c3a;
  --gold: #c9923a;
  --sky: #c5d9e0;
  --ghost: #7a7060;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
body {
  font-family: 'Outfit', sans-serif;
  background: var(--paper);
  min-height: 100vh; min-height: 100dvh;
  color: var(--ink); -webkit-font-smoothing: antialiased;
  padding-bottom: env(safe-area-inset-bottom, 20px);
}

/* Subtle grain overlay */
body::before {
  content: '';
  position: fixed; inset: 0; pointer-events: none; z-index: 999;
  opacity: 0.025;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
}

.header {
  background: var(--forest);
  padding: 18px 20px 20px;
  padding-top: max(18px, env(safe-area-inset-top));
  color: var(--paper);
  border-bottom: 3px solid var(--gold);
}
.header-inner { display:flex; justify-content:space-between; align-items:center; max-width:500px; margin:0 auto; }
.header-title-block { display: flex; align-items: baseline; gap: 10px; }
.header h1 {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 30px; font-weight: 600;
  letter-spacing: 0; line-height: 1;
  color: var(--paper);
}
.header-divider { width: 1px; height: 22px; background: rgba(255,255,255,0.2); }
.header .subtitle {
  font-size: 11px; font-weight: 300;
  color: var(--mist); letter-spacing: 1.2px;
  text-transform: uppercase;
}
.collection-badge {
  background: transparent; border: 1px solid rgba(255,255,255,0.2);
  border-radius: 6px; padding: 7px 12px;
  display: flex; align-items: center; gap: 6px;
  cursor: pointer; color: var(--paper); font-size: 13px; font-weight: 400;
}

.nav-tabs { display:flex; max-width:500px; margin:0 auto; padding:10px 20px 0; gap:0; background: var(--paper); border-bottom: 1px solid var(--sand); }
.nav-tab { flex:1; padding:10px 0; border-radius:0; border:none; border-bottom: 2px solid transparent;
  font-weight: 500; font-size: 13px; cursor: pointer; transition: all 0.2s; background: transparent;
  color: var(--ghost); letter-spacing: 0.3px;
}
.nav-tab.active { color: var(--forest); border-bottom-color: var(--leaf); background: transparent; }

.content { max-width: 500px; margin: 0 auto; padding: 20px 20px 60px; }

.camera-btn {
  width: 100%; display: flex; align-items: center; justify-content: center; gap: 10px;
  padding: 18px 24px; border-radius: 8px;
  background: var(--forest); color: var(--paper);
  border: none; cursor: pointer;
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 16px; font-weight: 400; font-style: italic;
  transition: all 0.2s; -webkit-appearance: none;
}
.camera-btn:active { opacity: 0.85; transform: scale(0.99); }
.camera-btn.loading { background: var(--ghost); pointer-events: none; }

@keyframes spin { to { transform: rotate(360deg); } }
.spinner { display: inline-block; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.8s linear infinite; }

.overlay { position: fixed; inset: 0; background: rgba(30,28,24,0.8); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(4px); }
.overlay-card { background: var(--paper); border-radius: 10px; padding: 40px 32px; text-align: center; max-width: 300px; width: 90%; border: 1px solid var(--sand); }
.overlay-spinner { width: 44px; height: 44px; margin: 0 auto 20px; border: 2.5px solid var(--sand); border-top-color: var(--leaf); border-radius: 50%; animation: spin 0.8s linear infinite; }

.preview-img { width: 100%; height: 220px; object-fit: cover; border-radius: 8px; margin-bottom: 16px; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
.fade-in { animation: fadeIn 0.3s ease both; }
.fade-in-1 { animation-delay: 0.1s; }
.fade-in-2 { animation-delay: 0.2s; }

.result-card { background: white; border-radius: 8px; overflow: hidden; border: 1px solid var(--sand); margin-bottom: 8px; cursor: pointer; transition: all 0.15s; }
.result-card.top { border-left: 3px solid var(--gold); border-color: var(--sand); border-left-color: var(--gold); }
.result-card-inner { padding: 14px 16px; }
.result-header { display: flex; justify-content: space-between; align-items: flex-start; }
.result-category { font-size: 10px; color: var(--ghost); font-weight: 500; display: flex; align-items: center; gap: 5px; margin-bottom: 3px; letter-spacing: 0.8px; text-transform: uppercase; }
.result-name { font-family: 'Playfair Display', Georgia, serif; font-size: 18px; font-weight: 600; color: var(--ink); margin-bottom: 1px; }
.result-card.top .result-name { font-size: 21px; }
.result-latin { font-family: 'Playfair Display', Georgia, serif; font-size: 12px; color: var(--ghost); font-style: italic; margin-bottom: 8px; font-weight: 400; }
.confidence { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 10px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
.confidence.high { background: rgba(74,124,89,0.1); color: var(--leaf); }
.confidence.medium { background: rgba(201,146,58,0.12); color: var(--gold); }
.confidence.low { background: rgba(176,92,58,0.1); color: var(--rust); }
.save-btn { background: transparent; border: 1px solid var(--sand); border-radius: 6px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 15px; transition: all 0.2s; flex-shrink: 0; }
.save-btn.saved { background: var(--forest); border-color: var(--forest); }
.details { margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--warm); display: none; }
.details.open { display: block; }
.details p { font-size: 13px; color: #4a4640; line-height: 1.65; margin-bottom: 10px; }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 10px; }
.detail-item { background: var(--paper); border-radius: 6px; padding: 8px 10px; }
.detail-label { font-size: 10px; color: var(--ghost); margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.5px; }
.detail-value { font-size: 12px; font-weight: 600; color: var(--ink); }
.fun-fact { background: var(--warm); border-radius: 6px; padding: 10px 14px; display: flex; gap: 8px; align-items: flex-start; }
.fun-fact span { font-size: 13px; color: #6a4a20; line-height: 1.55; }
.toggle-hint { text-align: center; margin-top: 8px; font-size: 10px; color: var(--ghost); letter-spacing: 0.5px; text-transform: uppercase; }

.explore-title { font-size: 10px; font-weight: 600; color: var(--ghost); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; }
.explore-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
.explore-btn { background: white; border: 1px solid var(--sand); border-radius: 8px; padding: 13px 4px; cursor: pointer; text-align: center; transition: all 0.15s; -webkit-appearance: none; }
.explore-btn:active { background: var(--warm); transform: scale(0.95); }
.explore-icon { font-size: 24px; margin-bottom: 3px; }
.explore-label { font-size: 10px; font-weight: 500; color: var(--ghost); }

.howto { margin-top: 20px; background: var(--forest); border-radius: 8px; padding: 20px; }
.howto h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 16px; font-weight: 400; font-style: italic; color: var(--paper); margin-bottom: 10px; }
.howto p { font-size: 13px; color: var(--mist); line-height: 1.75; }
.tip-box { text-align: center; margin-top: 14px; padding: 10px; background: white; border-radius: 6px; font-size: 11px; color: var(--ghost); border: 1px solid var(--sand); }

.empty { text-align: center; padding: 60px 20px; }
.empty-icon { font-size: 52px; margin-bottom: 16px; }
.empty h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 20px; font-weight: 400; color: var(--ink); margin-bottom: 8px; }
.empty p { font-size: 14px; color: var(--ghost); }
.back-btn { background: white; border: 1px solid var(--sand); border-radius: 6px; padding: 8px 14px; cursor: pointer; font-weight: 500; font-size: 13px; margin-bottom: 16px; color: var(--ink); -webkit-appearance: none; }
.back-btn:active { background: var(--warm); }
.collection-item { display: flex; justify-content: space-between; align-items: center; background: white; border-radius: 8px; padding: 12px 16px; margin-bottom: 6px; border: 1px solid var(--sand); }
.collection-item-name { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; font-size: 15px; color: var(--ink); }
.collection-item-latin { font-family: 'Playfair Display', Georgia, serif; font-size: 11px; color: var(--ghost); font-style: italic; font-weight: 400; }
.remove-btn { background: none; border: none; font-size: 16px; cursor: pointer; opacity: 0.35; }
.section-title { font-family: 'Playfair Display', Georgia, serif; font-size: 24px; font-weight: 600; color: var(--ink); margin-bottom: 16px; }
.cat-title { font-size: 10px; font-weight: 600; color: var(--ghost); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 8px; margin-top: 20px; }
.hidden { display: none !important; }
.ai-badge { display: inline-flex; align-items: center; gap: 4px; background: var(--leaf); color: white; padding: 2px 7px; border-radius: 3px; font-size: 9px; font-weight: 600; letter-spacing: 0.8px; margin-left: 8px; text-transform: uppercase; }
.error-box { background: rgba(176,92,58,0.06); border: 1px solid rgba(176,92,58,0.2); border-radius: 8px; padding: 16px; margin-top: 16px; }
.error-box h4 { color: var(--rust); font-family: 'Playfair Display', Georgia, serif; font-size: 15px; font-weight: 400; margin-bottom: 6px; }
.error-box p { color: #6a3020; font-size: 13px; line-height: 1.5; }
</style>
</head>
<body>

<div class="overlay hidden" id="overlay">
  <div class="overlay-card">
    <div class="overlay-spinner"></div>
    <div id="overlayText" style="font-family:'Playfair Display',Georgia,serif; font-size:16px; color:var(--ink);">Analyserer bilde...</div>
  </div>
</div>

<div class="header">
  <div class="header-inner">
    <div>
      <h1>Naturkjenner <span class="ai-badge">AI</span></h1>
      <div class="subtitle">Identifiser planter, dyr og marint liv</div>
    </div>
    <button class="collection-badge" onclick="showCollection()">
      📋 <span id="collectionCount">0</span>
    </button>
  </div>
</div>

<div class="nav-tabs">
  <button class="nav-tab active" id="navHome" onclick="showHome()">🏠 Hjem</button>
  <button class="nav-tab" id="navCollection" onclick="showCollection()">📋 Samling</button>
</div>

<div class="content" id="content">
  <div id="homeView">
    <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="handleFile(event)">
    <button class="camera-btn" id="cameraBtn" onclick="document.getElementById('fileInput').click()">
      <span style="font-size:24px">📸</span> Ta bilde eller velg fra galleri
    </button>
    <div id="resultsArea"></div>
    <div id="exploreArea" style="margin-top:24px">
      <div class="explore-title">Utforsk arter</div>
      <div class="explore-grid">
        <button class="explore-btn" onclick="browseCategory('flowers')"><div class="explore-icon">🌸</div><div class="explore-label">Blomster</div></button>
        <button class="explore-btn" onclick="browseCategory('trees')"><div class="explore-icon">🌳</div><div class="explore-label">Trær</div></button>
        <button class="explore-btn" onclick="browseCategory('berries')"><div class="explore-icon">🍇</div><div class="explore-label">Bær</div></button>
        <button class="explore-btn" onclick="browseCategory('mushrooms')"><div class="explore-icon">🍄</div><div class="explore-label">Sopp</div></button>
        <button class="explore-btn" onclick="browseCategory('birds')"><div class="explore-icon">🦅</div><div class="explore-label">Fugler</div></button>
        <button class="explore-btn" onclick="browseCategory('animals')"><div class="explore-icon">🦌</div><div class="explore-label">Dyr</div></button>
        <button class="explore-btn" onclick="browseCategory('marine')"><div class="explore-icon">🐟</div><div class="explore-label">Fisk</div></button>
        <button class="explore-btn" onclick="browseCategory('shellfish')"><div class="explore-icon">🦀</div><div class="explore-label">Skalldyr</div></button>
        <button class="explore-btn" onclick="browseCategory('shells')"><div class="explore-icon">🐚</div><div class="explore-label">Skjell</div></button>
        <button class="explore-btn" onclick="browseCategory('seaweed')"><div class="explore-icon">🌿</div><div class="explore-label">Tang</div></button>
        <button class="explore-btn" onclick="browseCategory('insects')"><div class="explore-icon">🐛</div><div class="explore-label">Insekter</div></button>
        <button class="explore-btn" onclick="browseCategory('other')"><div class="explore-icon">⭐</div><div class="explore-label">Havliv</div></button>
      </div>
      <div class="howto">
        <h3>Slik bruker du</h3>
        <p>📸 <strong>Ta et bilde</strong> av arten du vil identifisere, eller velg fra galleriet ditt. AI vil analysere bildet og foreslå arter.</p>
      </div>
    </div>
  </div>

  <div id="browseView" class="hidden"></div>

  <div id="collectionView" class="hidden"></div>
</div>

