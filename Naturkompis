async function identifyWithGemini(base64Image) {
  const base64Data = base64Image.replace(/^data:image\/\w+;base64,/, '');
  const mimeMatch = base64Image.match(/^data:(image\/\w+);base64,/);
  const mimeType = mimeMatch ? mimeMatch[1] : 'image/jpeg';

  const prompt = `Du er en ekspert på norsk natur og brukes i en app for å identifisiere arter i naturen. Du ELSKER å identifisiere arter og er ivrig etter å finne alt levende i bildet!

HVA DU SKAL IDENTIFISIERE (vær ivrig!):
- Alle levende organismer: dyr, fugler, fisk, krabber, skalldyr, skjell, insekter, edderkopper, snegler, sjødyr, pattedyr, reptiler
- Alle planter: blomster, trær, busker, gress, mose, lav, sopp, bær, tang, tare, alger
- Også døde/tørkede naturlige organismer (f.eks. skjell på stranda, tørt sjøgress)

HVA DU SKAL IGNORERE (ikke identifiser disse):
- Menneskeskapte objekter: emballasje, produkter, møbler, bygninger, klær, tekst, logoer
- Mat som er tilberedt/bearbeidet på tallerkener
- Hvis bildet viser en krabbe på en stein – identifiser krabben! Steinen er bare bakgrunn.

VIKTIG: Hvis bildet inneholder MINST ÉN naturlig organisme, identifiser den! Svar kun med tomt array [] hvis det virkelig IKKE finnes noe levende/naturlig i bildet overhodet.

For HVER art du identifiserer (maks 3), gi følgende i et JSON-array:

[
  {
    "name": "Norsk navn",
    "latin": "Latinsk artsnavn",
    "category": "Bruk en av: 🌸 Blomst, 🌳 Tre, 🍇 Bær, 🍄 Sopp, 🐟 Fisk, 🦀 Skalldyr, 🐚 Skjell, 🌿 Tang/Tare, ⭐ Havliv, 🦭 Sjøpattedyr, 🦅 Fugl, 🦌 Dyr, 🌱 Plante, 🪨 Mose/Lav, 🐛 Insekt",
    "confidence": 85,
    "description": "Kort beskrivelse på norsk (1-2 setninger)",
    "habitat": "Hvor den finnes i Norge",
    "season": "Sesong",
    "rarity": "Svært vanlig / Vanlig / Uvanlig / Sjelden",
    "edible": true/false,
    "funFact": "En morsom eller interessant fakta på norsk"
  }
]

confidence skal være 0-100 basert på hvor sikker du er. Vær streng – bruk lav confidence hvis du er usikker.
Svar KUN med JSON-arrayet, ingen annen tekst.`;

  const response = await fetch(GEMINI_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      contents: [{
        parts: [
          { text: prompt },
          { inlineData: { mimeType, data: base64Data } }
        ]
      }],
      generationConfig: {
        temperature: 0.3,
        maxOutputTokens: 4096
      }
    })
  });

  if (!response.ok) {
    const errText = await response.text();
    throw new Error('API-feil: ' + response.status + ' – ' + errText.substring(0, 200));
  }

  const data = await response.json();
  const text = data.candidates?.[0]?.content?.parts?.[0]?.text || '';
  console.log('Gemini raw response:', text);

  let jsonStr = null;
  const startIdx = text.indexOf('[');
  if (startIdx !== -1) {
    let depth = 0;
    for (let i = startIdx; i < text.length; i++) {
      if (text[i] === '[') depth++;
      else if (text[i] === ']') { depth--; if (depth === 0) { jsonStr = text.substring(startIdx, i + 1); break; } }
    }
    if (!jsonStr) {
      let truncated = text.substring(startIdx);
      truncated = truncated.replace(/,\s*"[^"]*"?\s*:?\s*"?[^"]*$/, '');
      truncated = truncated.replace(/,\s*\{[^}]*$/, '');
      const openBraces = (truncated.match(/\{/g) || []).length - (truncated.match(/\}/g) || []).length;
      const openBrackets = (truncated.match(/\[/g) || []).length - (truncated.match(/\]/g) || []).length;
      for (let i = 0; i < openBraces; i++) truncated += '}';
      for (let i = 0; i < openBrackets; i++) truncated += ']';
      jsonStr = truncated;
    }
  }
  if (!jsonStr) throw new Error('Kunne ikke tolke AI-svaret. Rå respons: ' + text.substring(0, 200));

  let results;
  try { results = JSON.parse(jsonStr); }
  catch(e) {
    let fixed = jsonStr.replace(/,\s*([}\]])/g, '$1').replace(/[\x00-\x1f]/g, ' ');
    try { results = JSON.parse(fixed); }
    catch(e2) { throw new Error('JSON-parsing feilet: ' + e2.message); }
  }
  return results.map(r => ({
    name: r.name || 'Ukjent',
    latin: r.latin || '',
    category: r.category || '🌱 Plante',
    confidence: Math.min(99, Math.max(10, r.confidence || 50)),
    description: r.description || '',
    habitat: r.habitat || 'Norge',
    season: r.season || '',
    rarity: r.rarity || 'Ukjent',
    edible: !!r.edible,
    funFact: r.funFact || ''
  }));
}

