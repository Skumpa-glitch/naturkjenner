function isSaved(name) { return collection.some(s => s.name === name); }
function toggleSave(species) {
  if (isSaved(species.name)) collection = collection.filter(s => s.name !== species.name);
  else collection.push(species);
  updateCollectionCount();
}
function updateCollectionCount() { document.getElementById('collectionCount').textContent = collection.length; }

function confidenceHTML(conf) {
  const cls = conf >= 75 ? 'high' : conf >= 50 ? 'medium' : 'low';
  const label = conf >= 75 ? 'Høy' : conf >= 50 ? 'Middels' : 'Lav';
  return '<span class="confidence ' + cls + '">' + conf + '% ' + label + '</span>';
}

